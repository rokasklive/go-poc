# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

#ai
.agents
.claude

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# --- Wails v3 / frontend build artifacts ---
.task
/bin
/dist
frontend/node_modules
# NOTE: frontend/dist is intentionally NOT ignored — it is committed so that
# `go run github.com/rokasklive/go-poc@<tag>` can resolve //go:embed all:frontend/dist
# from the module proxy. Rebuild it with `cd frontend && npm run build` before tagging.
build/linux/appimage/build
build/windows/nsis/MicrosoftEdgeWebview2Setup.exe
# Generated Windows resource objects
*.syso
# Stray object files (Docker cross-build may leave a root-owned empty `-.o`)
*.o

# Local-only docs (excluded from the repo per request)
docs/
# Mobile generated (per-machine; overlays hold absolute paths)
build/ios/xcode/overlay.json
build/ios/xcode/gen/
build/android/overlay.json
build/android/gen/
